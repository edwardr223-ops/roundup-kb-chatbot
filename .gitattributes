# Force LF line endings for all text files
* text=auto eol=lf

# Explicitly mark text file types
*.css text eol=lf
*.html text eol=lf
*.js text eol=lf
*.json text eol=lf
*.jsx text eol=lf
*.md text eol=lf
*.sample text eol=lf
*.sh text eol=lf
*.svg text eol=lf
*.txt text eol=lf
*.yaml text eol=lf

# Binary files — do not modify
*.ico binary
*.png binary
*.zip binary
